rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Reads the requesting user's role from Firestore.
    // Falls back to 'VIEWER' if the user has no record — denies all writes.
    function userRole() {
      return isAuth()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'VIEWER')
        : 'NONE';
    }

    // Only the league superadmin can manage fixtures, standings config, and platform settings.
    function isSuperadmin() {
      return userRole() == 'SUPERADMIN';
    }

    // Club admins and editors can manage club-scoped content (rosters, news, media, stats).
    function isEditor() {
      return userRole() in ['SUPERADMIN', 'CLUB_ADMIN', 'EDITOR'];
    }

    // ── League-level data — superadmin writes only ────────────────────────────

    match /fixtures/{doc} {
      allow read: if true;
      allow write: if isSuperadmin();
    }

    match /deductions/{doc} {
      allow read: if true;
      allow write: if isSuperadmin();
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isSuperadmin();
    }

    match /sponsors/{doc} {
      allow read: if true;
      allow write: if isSuperadmin();
    }

    match /referees/{doc} {
      allow read: if true;
      allow write: if isSuperadmin();
    }

    // ── Pre-computed standings — written by Cloud Function, public read ──────
    match /standings/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ── Club and editorial data — editor+ writes ──────────────────────────────

    match /clubs/{clubId} {
      allow read: if true;
      allow write: if isEditor();

      match /players/{playerId} {
        allow read: if true;
        allow write: if isEditor();
      }

      match /products/{productId} {
        allow read: if true;
        allow write: if isEditor();
      }

      match /pages/{pageId} {
        allow read: if true;
        allow write: if isEditor();
      }

      match /academy/{teamId}/players/{playerId} {
        allow read: if isAuth();
        allow write: if isEditor();
      }

      // Trial sessions: admin manages, public reads (for the registration form)
      match /trial_sessions/{sessionId} {
        allow read: if true;
        allow write: if isEditor();
      }

      // Trial applications: anyone can submit (public form), editors can read/update
      match /trial_applications/{appId} {
        allow create: if true;
        allow read, update: if isEditor();
        allow delete: if isSuperadmin();
      }
    }

    match /player_stats/{doc} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /awards_potm/{doc} {
      allow read: if true;
      allow write: if isEditor();
    }

    // Unauthenticated clients may only read published articles.
    match /news/{doc} {
      allow read: if resource.data.status == 'published' || isAuth();
      allow write: if isEditor();
    }

    match /media_albums/{albumId} {
      allow read: if true;
      allow write: if isEditor();

      match /items/{itemId} {
        allow read: if true;
        allow write: if isEditor();
      }
    }

    // ── Admin-only collections — superadmin reads and writes ──────────────────

    match /disciplinary_suspensions/{doc} {
      allow read, write: if isSuperadmin();
    }

    match /disciplinary_fines/{doc} {
      allow read, write: if isSuperadmin();
    }

    match /disciplinary_decisions/{doc} {
      allow read, write: if isSuperadmin();
    }

    match /referee_assignments/{doc} {
      allow read, write: if isSuperadmin();
    }

    match /referee_availability/{doc} {
      allow read, write: if isSuperadmin();
    }

    match /referee_ratings/{doc} {
      allow read, write: if isSuperadmin();
    }

    // ── User management ───────────────────────────────────────────────────────
    // A user can always read their own record (needed by useAuth to resolve the role).
    // Superadmin can read and write all user records.
    // Writes to own record are intentionally excluded — user profiles are managed
    // by superadmin only to prevent privilege escalation.
    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow read, write: if isSuperadmin();
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
